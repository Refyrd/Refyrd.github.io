rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Feedback entries
    match /feedback/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['message', 'name', 'time', 'likes', 'dislikes', 'commentCount']);
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'dislikes', 'commentCount']);

      // Votes subcollection
      match /votes/{voteKey} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == voteKey
          && request.resource.data.keys().hasOnly(['type', 'userId', 'feedbackId', 'timestamp']);
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly(['name', 'message', 'uid', 'time']);
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasOnly(['message']);
        allow delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
